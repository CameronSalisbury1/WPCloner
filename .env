# Local WordPress Docker Environment
# These credentials are for local development only

DB_NAME=wordpress
DB_USER=wordpress
DB_PASSWORD=wordpress
DB_ROOT_PASSWORD=rootpassword

WORDPRESS_PORT=80
PHPMYADMIN_PORT=8081

# Disable all Gravity Forms email notifications (true/false)
DISABLE_GF_NOTIFICATIONS=true

# Redirect Make.com webhooks to this host (leave empty to keep production webhooks)
# GF_WEBHOOK_REDIRECT_HOST=func-nzn-wt-uat-grantsapi.azurewebsites.net
GF_WEBHOOK_REDIRECT_HOST=host.docker.internal:7071
GF_WEBHOOK_REDIRECT_HOST_IDS=88,53,67,19,42,127,63,87,95,89,54,119,33,55,27,68,107,106,109,20,62,10,12

# Waikato-Tainui Verify API URL (leave empty to keep production URL)
# WT_VERIFY_API_URL=https://func-nzn-wt-uat-grantsapi.azurewebsites.net/verify
WT_VERIFY_API_URL=http://host.docker.internal:7071/verify

# Waikato-Tainui Verify API Key (leave empty to keep production key)
WT_VERIFY_API_KEY=wt-webhook-secret-2024-hmac-signing

# Waikato-Tainui atanga token (leave empty to keep production value)
WT_ATANGA_TOKEN=haumaru

# Allow plugin/theme installation and updates (true/false)
# Set to false to enable the "Add Plugins" button in WordPress admin
DISALLOW_FILE_MODS=false

# Local admin account created during setup
LOCAL_ADMIN_USER=wtuatwpadmin
LOCAL_ADMIN_PASSWORD=password1234
LOCAL_ADMIN_EMAIL=wtuatwpadmin@edev.co.nz
