# Local WordPress Docker Environment
# These credentials are for local development only

DB_NAME=wordpress
DB_USER=wordpress
DB_PASSWORD=wordpress
DB_ROOT_PASSWORD=rootpassword

WORDPRESS_PORT=80
PHPMYADMIN_PORT=8081

# Disable all Gravity Forms email notifications (true/false)
DISABLE_GF_NOTIFICATIONS=true

# Redirect Make.com webhooks to this host (leave empty to keep production webhooks)
GF_WEBHOOK_REDIRECT_HOST=func-nzn-wt-uat-grantsapi.azurewebsites.net

# Allow plugin/theme installation and updates (true/false)
# Set to false to enable the "Add Plugins" button in WordPress admin
DISALLOW_FILE_MODS=false

# Local admin account created during setup (2FA will be disabled for this user)
LOCAL_ADMIN_USER=wtuatwpadmin
LOCAL_ADMIN_PASSWORD=password1234
LOCAL_ADMIN_EMAIL=wtuatwpadmin@edev.co.nz
